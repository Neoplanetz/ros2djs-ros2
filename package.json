{
  "name": "ros2-web2d",
  "homepage": "https://github.com/Neoplanetz/ros2-web2d",
  "description": "Web-based 2D visualization library for ROS 2 (rosbridge + EaselJS).",
  "version": "1.3.2",
  "license": "BSD-3-Clause",
  "main": "./build/ros2d.cjs.js",
  "module": "./build/ros2d.esm.js",
  "types": "./build/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/types/index.d.ts",
      "import": "./build/ros2d.esm.js",
      "require": "./build/ros2d.cjs.js"
    }
  },
  "dependencies": {
    "createjs-module": "^0.8.3",
    "easeljs": "^1.0.2",
    "eventemitter3": "^5.0.4"
  },
  "peerDependencies": {
    "roslib": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "roslib": {
      "optional": false
    }
  },
  "devDependencies": {
    "@rollup/plugin-buble": "^1.0.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "debug": "^4.3.0",
    "grunt": "^1.0.0",
    "grunt-contrib-clean": "^2.0.0",
    "grunt-contrib-watch": "^1.0.0",
    "grunt-execute": "git+https://github.com/gruntjs-updater/grunt-execute.git#peerDep",
    "grunt-jsdoc": "^2.1.0",
    "grunt-karma": "^4.0.0",
    "grunt-pipe": "git+https://github.com/RobotWebTools/grunt-pipe.git",
    "grunt-shell": "^4.0.0",
    "gruntify-eslint": "^5.0.0",
    "jsdom": "^29.0.2",
    "karma": "^6.3.0",
    "rimraf": "^5.0.10",
    "rollup": "^2.47.0",
    "rollup-plugin-filesize": "^10.0.0",
    "rollup-plugin-terser": "^7.0.0",
    "roslib": "^2.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Neoplanetz/ros2-web2d.git"
  },
  "bugs": {
    "url": "https://github.com/Neoplanetz/ros2-web2d/issues"
  },
  "scripts": {
    "prebuild": "rimraf src-esm && grunt transpile",
    "build": "rollup -c && npm run build:types",
    "build:types": "tsc -p tsconfig.json",
    "doc": "grunt doc",
    "lint": "grunt lint",
    "lint-fix": "grunt lint-fix",
    "transpile": "DEBUG=* grunt transpile",
    "check:transpile": "rimraf src-esm && grunt transpile && git diff --exit-code -- src-esm/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "publish": "npm run build"
  },
  "keywords": [
    "ros",
    "ros2",
    "rosbridge",
    "roslib",
    "2d",
    "web",
    "visualization",
    "easeljs",
    "canvas"
  ],
  "author": "Neoplanetz <hwchung98@gmail.com>",
  "directories": {
    "example": "examples"
  }
}
